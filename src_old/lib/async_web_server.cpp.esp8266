extern void set_screen_brt(int brt);
void handleSet(AsyncWebServerRequest * request){
  String message = "OK";
  if (request->hasArg("ct") && request->hasArg("cf") && request->hasArg("cd")){
    String city  = request->arg("ct");
    if(city != cityName){
      cityName = city;
      //update_weather(true);
      set_city_config("", 0, 0, city.c_str(), "");
      wea.cityCode = cityCode;
    }
    //cityName  = server.arg("ct");
    cityFont  = request->arg("cf");
    cityCode  = request->arg("cd");
    Serial.printf("cityname:%s\r\n",cityName);
    Serial.printf("cityFont:[%s]\r\n",cityFont);
    Serial.printf("cityCode:[%s]\r\n",cityCode);
    //set_city_config(cityName.c_str(), cityFont.c_str(), cityCode.c_str());
   }else if (request->hasArg("key")) {
    weather_key = request->arg("key");
    //Serial.printf("key:[%s]\r\n",weather_key);
    if(weather_key == ""){
      //Serial.printf("error key");
    }else {
      set_key_config(weather_key);
      //update_weather(true);
      wea.usr_weather_key = weather_key;
      //wea.update(false);
      //立刻使用用户的key更新天气
      wea.update(true);
      //weather_changed = true;
    }

  }else if (request->hasArg("brt")) {
    brt  = request->arg("brt").toInt();
    Serial.printf("brt:[%d]\r\n",brt);
    //todoifeng analogWrite(5, 250-brt);//200 是比较合适的亮度
    set_screen_brt(brt);
    set_brt_config(brt);
  }else if(request->hasArg("b1") && request->hasArg("b2") && request->hasArg("t1")){
    t1 = request->arg("t1").toInt();
    t2 = request->arg("t2").toInt();
    b2 = request->arg("b2").toInt();
    timer_brt_en = request->arg("en").toInt();
    /* 小时发生变化，立刻更新小时 */
    set_timer_brt_config(timer_brt_en, t1, t2, b2);
    Serial.printf("en:[%d]%d,%d,%d,%d\r\n",timer_brt_en, t1, t2, b2);
 }else if (request->hasArg("hour")) {
    hour12  = request->arg("hour").toInt();
    Serial.printf("hour12:[%d]\r\n",hour12);
    set_hour12_config(hour12);
  }else if (request->hasArg("theme")) {
    theme_index = request->arg("theme").toInt();
    Serial.printf("theme:[%d]\r\n", theme_index);
    set_theme_config(theme_index);
    //退出相册轮播
    if(theme_index != 3) app_exit = 1;
 }else if (request->hasArg("hc")) {
    char hex[8] = {0};
    snprintf(hex, sizeof(hex),"%s",request->arg("hc").c_str());
    h1_color = (int)strtol(hex, NULL, 16);
    Serial.printf("hc:[%X]\r\n",h1_color);
    set_time_color_config(h1_color, m1_color, s1_color);
    force_time_display = 1;
  }else if (request->hasArg("mc")) {
    char hex[8] = {0};
    snprintf(hex, sizeof(hex),"%s",request->arg("mc").c_str());
    m1_color = (int)strtol(hex, NULL, 16);
    Serial.printf("m1 color:[%d]\r\n",m1_color);
    set_time_color_config(h1_color, m1_color, s1_color);
    force_time_display = 1;
  }else if (request->hasArg("sc")) {
    char hex[8] = {0};
    snprintf(hex, sizeof(hex),"%s",request->arg("sc").c_str());
    s1_color = (int)strtol(hex, NULL, 16);
    Serial.printf("s1 color:[%d]\r\n",s1_color);
    set_time_color_config(h1_color, m1_color, s1_color);
    force_time_display = 1;
  }else if (request->hasArg("bili")) {
    bili_id = request->arg("bili");
    Serial.printf("bili:[%s]\r\n",bili_id);
    set_bili_config(bili_id.c_str());
  }else if (request->hasArg("album")) {
    album_time = request->arg("album").toInt();
    Serial.printf("album:[%d]\r\n",album_time);
    set_album_config(album_time);
  }else if (request->hasArg("stock") && request->hasArg("exchange")) {
    stock_code = request->arg("stock");
    stock_exchange = request->arg("exchange");
    Serial.printf("stock:[%s][%s]\r\n",stock_code, stock_exchange);
    set_stock_config(stock_code.c_str(), stock_exchange.c_str());
 }else{
    message = "FAIL";
  }

 request->send_P(200, "text/plain", message.c_str());
 return;
}

const char * listDir(fs::FS &fs, const char * dirname, uint8_t levels) {
    // filelist = "";
    String partlist;
    int i = 0;
    // Serial.printf("Listing directory: %s\r\n", dirname);
    File root;
    if(dirname == NULL || dirname[0] == '\0')
        root = fs.open("/image","r");
    else
        root = fs.open(dirname, "r");

    Serial.println(dirname);
    if (!root) {
        Serial.println("- failed to open directory");
        return "failed to open dir";
    }
    if (!root.isDirectory()) {
        Serial.println(" - not a directory");
        return "not dir";
    }

    File file = root.openNextFile();
    if (!file) {
        Serial.println("- failed to open next file");
        return "failed to open next";
    }
    while (file) {
    #if 0
        if (file.isDirectory()) {
        //  Serial.print("  DIR : ");
        // Serial.println(file.name());
        if (levels) {
            listDir(fs, file.name(), levels - 1);
        }
        } else 
    #endif    
        {
            i++;
            String st_after_symb = String(file.name()).substring(String(file.name()).lastIndexOf("/") + 1);

            Serial.print(file.name());
            
            if (file.isDirectory()) 
                partlist +=  String("<tr><td>") + String(i) + String("</td><td>") + String("<a href='javascript:void(0);' path='") + String(file.name()) + String("' onclick='listDir(this);return false;'>") + st_after_symb + String("</a></td><td> - </td><td>") + String(" ") + String("</td></tr>");
            else
                partlist +=  String("<tr><td>") + String(i) + String("</td><td>") + String("<a href='") + String(dirname) + String("/") + String(file.name()) + String("'>") + st_after_symb + String("</a></td><td>") + String(file.size() / 1024) + String("</td><td>") + String("<input type='button' class='btndel' onclick=\"deletef('") +String(dirname)+String("/")+ String(file.name()) + String("')\" value='X'>") + String("</td></tr>");
            //filelist = String("<table id='list'><tbody><tr><th>#</th><th>File name</th><th>Size(KB)</th><th></th></tr>") + partlist + String(" </tbody></table>");
        }
        file = root.openNextFile();
    }
    //Serial.println(partlist);
    filelist = String("<table id='list'><tbody><tr><th>#</th><th>文件名</th><th>大小(KB)</th><th></th></tr>") + partlist + String(" </tbody></table>");
    return filelist.c_str();
}

String processor_update(const String& var) {
    Serial.println("received "+var);
    listDir(LittleFS,"/image",0);
    if (var == "list") {
        return filelist;
    }
    return String();
}

void notFound(AsyncWebServerRequest *request) {
  if (request->url().startsWith("/")) {
    //request->send(SD, request->url(), String(), true);
    request->send(LittleFS, request->url(), String(), false);
  } else {
    request->send(404);
  }
}
