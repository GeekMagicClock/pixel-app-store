MatrixPanel_I2S_DMA *mdisplay = nullptr;

uint16_t myBLACK = mdisplay->color565(0, 0, 0);
uint16_t myWHITE = mdisplay->color565(255, 255, 255);
uint16_t myRED = mdisplay->color565(255, 0, 0);
uint16_t myGREEN = mdisplay->color565(0, 255, 0);
uint16_t myBLUE = mdisplay->color565(0, 0, 255);


